# =============================================================================
# VERCEL — copy these into Project → Settings → Environment Variables
# Use the SAME values as your main site (flashfire-webiste-frontend-nextjs) where listed.
# =============================================================================
#
# Required
#   NEXT_PUBLIC_API_BASE_URL
#
# Recommended (match main site for analytics / ads parity)
#   NEXT_PUBLIC_POSTHOG_KEY
#   NEXT_PUBLIC_POSTHOG_HOST
#   NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID
#   NEXT_PUBLIC_LINKEDIN_PARTNER_ID
#   NEXT_PUBLIC_LINKEDIN_SCHEDULE_CONVERSION_ID
#   NEXT_PUBLIC_LINKEDIN_LEAD_CONVERSION_ID
#
# Optional
#   NEXT_PUBLIC_CAMPAIGN_BASE_URL
#   NEXT_PUBLIC_GA_MEASUREMENT_ID          (defaults to G-4P890VGD8D in code if unset)
#   NEXT_PUBLIC_FB_PIXEL_ID                (defaults to main site pixel if unset)
#   NEXT_PUBLIC_LINKEDIN_PURCHASE_CONVERSION_ID
#   NEXT_PUBLIC_LINKEDIN_SIGNUP_CONVERSION_ID
#   NEXT_PUBLIC_REF_TRACKING_URL
#
# Do NOT add MongoDB, Discord webhooks, or backend keys — those go on the API server only.
# =============================================================================

NEXT_PUBLIC_API_BASE_URL=https://api.flashfirejobs.com
NEXT_PUBLIC_CAMPAIGN_BASE_URL=https://www.flashfirejobs.com

# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

